# Скопируй в .env (он в .gitignore). Значения ниже — для локальной разработки.

# PostgreSQL (Docker)
POSTGRES_USER=termosphere
POSTGRES_PASSWORD=termosphere
POSTGRES_DB=termosphere
# 5433/5434 заняты другими локальными проектами → 5435
DB_PORT=5435

# Строка подключения приложения (SQLAlchemy, драйвер psycopg3).
# Для локального uvicorn/ETL — localhost:5435. В docker-compose api получает
# свой DATABASE_URL (db:5432) из окружения, эта строка на контейнер не влияет.
DATABASE_URL=postgresql+psycopg://termosphere:termosphere@localhost:5435/termosphere

# Хостовые порты docker-контура (Фаза 4). 8000 занят другим проектом → api на 8010.
API_PORT=8010
WEB_PORT=8090

# Basic-auth публичного дашборда. Задать свои значения и сгенерировать хеш:
#   mkdir -p deploy && printf '%s:%s\n' "$WEB_AUTH_USER" "$(openssl passwd -apr1 'ПАРОЛЬ')" > deploy/htpasswd
# Файл deploy/htpasswd монтируется в web-контейнер (в git не коммитится).
# Оставь файл читаемым (по умолчанию 644/664); chmod 600 сломает nginx (uid воркера ≠ владелец → 500).
WEB_AUTH_USER=termosphere
WEB_AUTH_PASS=change-me

# --- Шаг 7: Metabase (BI, docker-профиль bi) ---
# BI-хостнейм закрыт собственным логином Metabase (email+пароль ниже), отдельного
# basic-auth на нём нет — один запрос авторизации. Сам Metabase наружу не торчит.
MB_ADMIN_EMAIL=admin@termosphere.local
MB_ADMIN_PASSWORD=change-me-strong        # >=8 симв., смешанный регистр+цифра+символ
MB_SITE_NAME=ТермоСфера BI
MB_DB_USER=metabase
MB_DB_PASSWORD=change-me
MB_DB_NAME=metabaseapp
MB_DIRECT_PORT=3010                        # 127.0.0.1: Metabase напрямую (провижининг)
MB_PROXY_PORT=8091                         # 127.0.0.1: nginx-прокси (цель туннеля)
